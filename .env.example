# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — it will NEVER be committed.
#
# Server-side only. Never prefix secret keys with NEXT_PUBLIC_, or they
# will be bundled into the browser-visible JavaScript.

OPENAI_API_KEY=

# IBM Orchestrate — fill these in .env.local to activate /api/orchestrate/chat
ORCHESTRATE_API_KEY=        # IBM Cloud API key
ORCHESTRATE_AGENT_ID=       # deployed agent/assistant ID
ORCHESTRATE_ENDPOINT=       # full URL to your agent's inference endpoint
ORCHESTRATE_INSTANCE_ID=    # IBM instance ID (leave blank if not required)
